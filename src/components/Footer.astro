---
---
<section id="download" class="cta" data-folio>
  <div class="container">
    <div class="cta-card">
      <p class="eyebrow"><span class="roman">VIII</span><span>Find it</span></p>
      <h2 class="cta-title">Take it for an <em>evening.</em></h2>
      <p class="cta-lede">
        JustWrite is free and open. Download it for desktop,
        or browse the source. If you write something with it,
        we would love to hear about it.
      </p>

      <div class="cta-actions">
        <a class="btn" href="https://github.com/delebash/justwrite-app">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.73.5.67 5.57.67 11.85c0 5 3.24 9.24 7.75 10.74.57.1.78-.25.78-.55v-2c-3.15.68-3.81-1.34-3.81-1.34-.52-1.31-1.27-1.66-1.27-1.66-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.52-.29-5.16-1.26-5.16-5.6 0-1.24.44-2.25 1.17-3.04-.12-.29-.51-1.43.11-2.98 0 0 .96-.31 3.16 1.16.92-.26 1.9-.39 2.88-.39s1.96.13 2.88.39c2.2-1.47 3.16-1.16 3.16-1.16.62 1.55.23 2.69.11 2.98.73.79 1.17 1.8 1.17 3.04 0 4.35-2.64 5.3-5.17 5.59.41.35.78 1.04.78 2.1v3.11c0 .31.21.66.79.55 4.51-1.5 7.74-5.74 7.74-10.74C23.33 5.57 18.27.5 12 .5z"/>
          </svg>
          <span>Browse on GitHub</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="btn btn--gold" href="https://github.com/delebash/justwrite-app/releases/latest">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/>
          </svg>
          <span>Latest release</span>
        </a>
      </div>

      <ul class="cta-ports" aria-label="Available for">
        <li><span class="port-mono">macOS</span><span class="port-em">.dmg · arm64 / x64</span></li>
        <li><span class="port-mono">Windows</span><span class="port-em">.exe · x64</span></li>
        <li><span class="port-mono">Linux</span><span class="port-em">.AppImage · .deb · .rpm</span></li>
      </ul>
    </div>
  </div>
</section>

<footer class="page-footer">
  <div class="container footer-container">
    <div class="foot-brand">
      <span class="foot-mark">J</span>
      <span class="foot-name"><em>JustWrite</em></span>
    </div>
    <div class="foot-meta">
      <p>
        A typographic homage to the works that take more than an afternoon.
        Set in <em>Fraunces</em>, <em>Spline Sans</em>, and <em>Spline Sans Mono</em>.
      </p>
      <p class="foot-credit">
        Code written by Claude. Words written by humans. Read more in
        <a href="#colophon">the colophon</a>.
      </p>
    </div>
    <div class="foot-links">
      <a href="https://github.com/delebash/justwrite-app">GitHub</a>
      <a href="https://github.com/anthropics/claude-code">Claude Code</a>
      <a href="#top">↑ Top</a>
    </div>
  </div>
</footer>

<style>
  .cta {
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }
  .cta-card {
    position: relative;
    padding: clamp(2.5rem, 6vw, 5rem) clamp(2rem, 5vw, 4.5rem);
    border-radius: var(--r-xl);
    background:
      radial-gradient(700px 400px at 20% 20%, oklch(0.62 0.10 14 / 0.12), transparent 60%),
      radial-gradient(500px 400px at 90% 80%, oklch(0.62 0.10 80 / 0.10), transparent 60%),
      var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-2);
    overflow: hidden;
  }
  .cta-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, var(--accent-line), transparent 40%, var(--gold-soft) 90%);
    -webkit-mask: linear-gradient(black, black) content-box, linear-gradient(black, black);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
    opacity: 0.6;
  }

  .cta-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2.25rem, 5vw, 4rem);
    line-height: 1.0;
    letter-spacing: -0.03em;
    margin: 1rem 0 0;
    color: var(--ink);
  }
  .cta-title em { font-style: italic; color: var(--accent); }
  .cta-lede {
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 36rem;
    margin: 1.5rem 0 2.5rem;
  }

  .cta-actions {
    display: flex; flex-wrap: wrap; gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .cta-ports {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 1rem;
    list-style: none;
    padding: 1.5rem 0 0;
    margin: 0;
    border-top: 1px solid var(--border);
  }
  .cta-ports li {
    display: flex; flex-direction: column;
    gap: 0.2rem;
  }
  .port-mono {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .port-em {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--ink-2);
  }

  .page-footer {
    padding: 3rem var(--gutter) 4rem;
    border-top: 1px solid var(--border);
  }
  .footer-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: end;
  }
  @media (min-width: 720px) {
    .footer-container {
      grid-template-columns: auto 1fr auto;
    }
  }

  .foot-brand { display: flex; align-items: center; gap: 0.6rem; }
  .foot-mark {
    width: 26px; height: 26px;
    border-radius: 6px;
    background: linear-gradient(135deg, var(--accent), oklch(0.52 0.10 320));
    color: white; display: grid; place-items: center;
    font-family: var(--font-serif); font-style: italic;
    font-weight: 700; font-size: 14px;
  }
  .foot-name {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--ink);
  }
  .foot-name em { font-style: italic; }

  .foot-meta { color: var(--muted); }
  .foot-meta p {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0 0 0.5rem;
  }
  .foot-meta em { color: var(--ink-2); font-style: italic; }
  .foot-credit a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--accent-line);
    text-underline-offset: 3px;
  }
  .foot-credit a:hover {
    text-decoration-color: var(--accent);
  }

  .foot-links {
    display: flex; gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .foot-links a:hover { color: var(--accent); }
</style>
