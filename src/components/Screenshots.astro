---
const { roman = "VI" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// Build-time cache-buster. Astro frontmatter runs once per build, so every
// deploy gets a fresh ?v=… that forces browsers to re-fetch the PNGs even
// when their filenames haven't changed.
const v = Date.now();
const shot = (name) => `${base}/screenshots/${name}?v=${v}`;

// Real screenshots from the app. Add more files to /public/screenshots/
// and append to this array.
const shots = [
  {
    file: "home-light.png",
    label: "Home",
    title: "A daily ledger of the work.",
    caption: "Word goal, deadline, the day's session, fortnight, cadence — and a button that drops you back into the chapter you were last in.",
    alt: "JustWrite Home — project goal, today's session, fortnight, cadence",
    span: "wide",
  },
  {
    file: "editor.png",
    label: "Manuscript",
    title: "A typesetter's page, with scene cards.",
    caption: "Edit the prose, or step back to the chapter's scene cards. A quiet serif page in the middle, the manuscript spine on the left, AI tools — critique, multi-reader panel, line edits, versions — across the top.",
    alt: "JustWrite manuscript editor — Card view of a chapter with four scenes",
    span: "wide",
  },
  {
    file: "characters.png",
    label: "Characters",
    title: "Wants, needs, and the lie they tell.",
    caption: "Each character has wants, needs, the lie they tell themselves, the truth they deny — and a three-act arc. A consistency audit flags contradictions across chapters; a relationship-arc tracker maps how each bond evolves.",
    alt: "JustWrite Characters — protagonist detail with motivation grid and three-act arc",
    span: "wide",
  },
  {
    file: "worldbuilding.png",
    label: "Worldbuilding",
    title: "A wiki for the world around the book.",
    caption: "Free-form articles organised by category — Geography, History, Cultures, Languages, Factions, Lore & myth. Tag them; cross-reference them; search them.",
    alt: "JustWrite Worldbuilding — category filters and articles for the novel's world",
    span: "wide",
  },
  {
    file: "relations.png",
    label: "Relations",
    title: "Everyone and everything, in one graph.",
    caption: "Characters, locations, objects, narrative strands. Edges drawn from shared scenes, shared groups, shared mentions. You don't draw them here; they appear automatically from the work you do everywhere else.",
    alt: "JustWrite Relations — force-directed graph of every story-world entity",
    span: "wide",
  },
  {
    file: "plotboard.png",
    label: "Plot board",
    title: "Strands across chapters.",
    caption: "Each narrative strand reads as a row; each chapter a column. Drop a beat on the grid and it links back to its scenes. Templates included — Three-Act, Save the Cat, Hero's Journey, Story Circle — or build one from scratch.",
    alt: "JustWrite Plot board — five narrative strands across thirteen chapters",
    span: "wide",
  },
  {
    file: "timeline.png",
    label: "Timeline",
    title: "The story's chronology, laid flat.",
    caption: "Every event you attach to a character, location, object, group, or the setting — sorted by in-story date. Click an event to jump to its source; the order reads cleanly even when the chapters don't.",
    alt: "JustWrite Timeline — chronological event list with dates and entity tags",
    span: "wide",
  },
  {
    file: "analysis.png",
    label: "Analysis",
    title: "A reading of the work.",
    caption: "KPIs and a 30-day pace chart up top, then a 53-week heatmap, milestones, status breakdown, narrative strands by word count — and AI surfaces below for story-tension, voice-drift, reverse outline, and plot-hole audit.",
    alt: "JustWrite Analysis — KPIs, pace chart, writing heatmap, milestones, status, strands",
    span: "wide",
  },
  {
    file: "writer-lab.png",
    label: "Writer Lab",
    title: "Look inside the AI calls.",
    caption: "Every AI feature, broken open: rewrite, expand, tighten, sensory weave, sentence variety, prose tightening, critique notes, structural analysis. Useful when you want to know what the model is actually being asked — or when you're tuning a local model.",
    alt: "JustWrite Writer Lab — grid of AI experiment cards across prose passes and analysis",
    span: "wide",
  },
  {
    file: "studio.png",
    label: "Studio · Cast",
    title: "A voice for everyone in the book.",
    caption: "Assign each character — and the narrator — to a voice from any TTS provider you've added. Smart-cast suggests pairings; render the chapter into an .m4b when you're ready.",
    alt: "JustWrite Studio — Cast & voices, characters with voice pickers, voice library",
    span: "wide",
  },
  {
    file: "settings-ai.png",
    label: "Settings · AI",
    title: "Bring your own. Plural.",
    caption: "Set defaults — LLM, TTS, embedding — then override per feature. Manuscript chat, critique, entity extraction, writer access, name suggest — every AI surface can be pinned to a different provider and model.",
    alt: "JustWrite Settings — AI defaults and per-feature routing matrix",
    span: "wide",
  },
  {
    file: "settings-appearance.png",
    label: "Settings · Appearance",
    title: "Theme presets, or tune your own.",
    caption: "Studio, Fine Press, Ivory Press, Calm Modern, Editorial. A live preview pane shows your settings against a real page. Light, dark, or follow the system. Save your mix as a preset.",
    alt: "JustWrite Settings — Appearance theme presets with live preview pane",
    span: "wide",
  },
];
---
<section id="sketches" class="screenshots" data-folio>
  <div class="container">
    <header class="screenshots-head">
      <p class="eyebrow"><span class="roman">{roman}</span><span>Sketches</span></p>
      <h2 class="section-title">From the <em>studio.</em></h2>
      <p class="section-lede">
        Real captures from the working app, against a real novel-in-progress —
        the same rooms, seen from the desk.
      </p>
    </header>

    <div class="gallery">
      {shots.map((s, i) => (
        <figure class={`shot shot--${s.span}`} style={`--i:${i}`}>
          <div class="shot-frame">
            <img src={shot(s.file)} alt={s.alt} loading="lazy" decoding="async" data-zoomable />
          </div>
          <figcaption>
            <span class="cap-label">{s.label}</span>
            <span class="cap-title">{s.title}</span>
            <span class="cap-text">{s.caption}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .screenshots-head { max-width: 56rem; margin-bottom: clamp(3rem, 6vw, 5rem); }

  .gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
  }

  .shot {
    margin: 0;
    display: grid;
    gap: clamp(1.25rem, 2.5vw, 2rem);
    align-items: center;
  }
  @media (min-width: 900px) {
    .shot {
      grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
    }
    .shot:nth-child(even) {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.55fr);
    }
    .shot:nth-child(even) .shot-frame { order: 2; }
    .shot:nth-child(even) figcaption { order: 1; }
  }

  .shot-frame {
    border-radius: var(--r-lg);
    border: 1px solid var(--border-strong);
    background: var(--surface);
    overflow: hidden;
    box-shadow: var(--shadow-2);
    line-height: 0;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .shot-frame:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-window);
    border-color: var(--accent-line);
  }
  .shot-frame img {
    display: block;
    width: 100%;
    height: auto;
  }

  figcaption {
    display: flex; flex-direction: column;
    gap: 0.6rem;
    padding: 0 0.25rem;
  }
  .cap-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .cap-title {
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2vw, 1.65rem);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.018em;
    color: var(--ink);
    margin-top: 0.2rem;
  }
  .cap-text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 38ch;
  }
</style>
