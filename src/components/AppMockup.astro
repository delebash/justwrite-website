---
// Stylized mockup of the JustWrite app — mirrors the real sidebar
// (Manuscript / Story world / Planning / Audio / Project) and the
// editor toolbar above the manuscript page.
---
<div class="mockup" aria-hidden="true">
  <div class="mockup-bg" aria-hidden="true"></div>

  <div class="mockup-window">
    <!-- Titlebar -->
    <div class="mockup-titlebar">
      <div class="dots">
        <span></span><span></span><span></span>
      </div>
      <div class="title">JustWrite — <em>The Cartographer's Daughter</em></div>
      <div class="title-right">
        <span class="kbd">⌘</span><span class="kbd">F</span>
        <span class="theme-pill" aria-hidden="true"></span>
      </div>
    </div>

    <div class="mockup-body">
      <!-- Sidebar -->
      <aside class="mockup-side">
        <!-- Brand -->
        <div class="m-brand">
          <span class="m-mark">J</span>
          <span class="m-brand-text">
            <span class="m-name">JustWrite</span>
            <span class="m-sub">a writing desk</span>
          </span>
        </div>

        <!-- Project switcher -->
        <div class="m-proj">
          <div class="m-proj-main">
            <div class="m-proj-title">The Cartographer's Daughter</div>
            <div class="m-proj-meta">Autosaved · just now</div>
          </div>
          <span class="m-proj-chev">⌄</span>
        </div>

        <!-- Section: Manuscript -->
        <div class="m-section">Manuscript</div>
        <ul>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="7" cy="7" r="4.5"/><path d="m10.5 10.5 3 3"/></svg></span>
            <span class="m-lab">Search</span>
            <span class="m-kbd">⌘F</span>
          </li>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 7l6-5 6 5v6.5a.5.5 0 0 1-.5.5h-3v-4h-5v4h-3a.5.5 0 0 1-.5-.5V7z"/></svg></span>
            <span class="m-lab">Home</span>
          </li>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="2" width="10" height="12" rx="0.5"/><path d="M3 5h10M3 8h10M3 11h10M7 2v12"/></svg></span>
            <span class="m-lab">Architecture</span>
            <span class="m-chev">›</span>
          </li>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 4c2 0 2 8 5 8s3-8 5-8"/><path d="M3 8c2 0 2 4 5 4s3-4 5-4"/></svg></span>
            <span class="m-lab">Narrative strands</span>
            <span class="m-chev">›</span>
          </li>
          <li class="active">
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h7a2 2 0 0 1 2 2v8H5a2 2 0 0 1-2-2V3z"/><path d="M3 11h7a2 2 0 0 1 2 2"/></svg></span>
            <span class="m-lab">Chapters</span>
            <span class="m-chev open">›</span>
          </li>

          <!-- Expanded chapters -->
          <li class="m-children">
            <div class="m-sub-head">Part One — Arrivals</div>
            <ul class="m-chap-list">
              <li class="active">
                <span class="m-num">1</span>
                <span class="m-chap-label">The Quiet Hour</span>
                <span class="m-words">2,184</span>
                <span class="m-dot" data-status="draft"></span>
              </li>
              <li>
                <span class="m-num">2</span>
                <span class="m-chap-label">A Letter Lost</span>
                <span class="m-words">1,902</span>
                <span class="m-dot" data-status="draft"></span>
              </li>
              <li>
                <span class="m-num">3</span>
                <span class="m-chap-label">Confession</span>
                <span class="m-words">3,041</span>
                <span class="m-dot" data-status="done"></span>
              </li>
            </ul>
            <div class="m-sub-head">Part Two — The River</div>
            <ul class="m-chap-list">
              <li>
                <span class="m-num">4</span>
                <span class="m-chap-label">Hollow House</span>
                <span class="m-words">488</span>
                <span class="m-dot" data-status="todo"></span>
              </li>
            </ul>
          </li>

          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2v3M8 11v3M2 8h3M11 8h3M3.5 3.5l2 2M10.5 10.5l2 2M3.5 12.5l2-2M10.5 5.5l2-2"/></svg></span>
            <span class="m-lab">Ask the book</span>
            <span class="m-kbd">⌘J</span>
          </li>
        </ul>

        <!-- Section: Story world -->
        <div class="m-section">Story world</div>
        <ul>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="6" r="2.5"/><path d="M2 13c0-2 2-3.5 4-3.5s4 1.5 4 3.5"/><circle cx="11" cy="5.5" r="2"/><path d="M14 12c0-1.5-1.4-3-3-3"/></svg></span>
            <span class="m-lab">Characters</span>
            <span class="m-count">14</span>
          </li>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 1.5C5 1.5 3 3.5 3 6.2c0 3.5 5 8.3 5 8.3s5-4.8 5-8.3C13 3.5 11 1.5 8 1.5z"/><circle cx="8" cy="6" r="1.7"/></svg></span>
            <span class="m-lab">Locations</span>
            <span class="m-count">7</span>
          </li>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 1.5 14 5v6L8 14.5 2 11V5z"/><path d="M2 5l6 3.5M14 5l-6 3.5M8 8.5v6"/></svg></span>
            <span class="m-lab">Objects</span>
            <span class="m-count">9</span>
          </li>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="5" cy="5" r="2"/><circle cx="11" cy="5" r="2"/><circle cx="8" cy="11" r="2"/></svg></span>
            <span class="m-lab">Groups</span>
            <span class="m-count">3</span>
          </li>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m8 2 1.5 4.5L14 8l-4.5 1.5L8 14l-1.5-4.5L2 8l4.5-1.5z"/></svg></span>
            <span class="m-lab">Worldbuilding</span>
            <span class="m-count">22</span>
          </li>
        </ul>

        <!-- Section: Planning -->
        <div class="m-section">Planning</div>
        <ul>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2.5" y="2.5" width="4" height="11" rx="0.5"/><rect x="9.5" y="2.5" width="4" height="6" rx="0.5"/></svg></span>
            <span class="m-lab">Plot board</span>
          </li>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 8h12M5 4v8M9 4v8M13 4v8"/></svg></span>
            <span class="m-lab">Timeline</span>
          </li>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 2h6l3 3v9H4z"/><path d="M10 2v3h3M6 8h5M6 11h5"/></svg></span>
            <span class="m-lab">Notes</span>
            <span class="m-count">31</span>
          </li>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="3.5" cy="3.5" r="1.5"/><circle cx="12.5" cy="3.5" r="1.5"/><circle cx="8" cy="12.5" r="1.5"/><path d="M4.5 4.5 7 11M11.5 4.5 9 11M5 3.5h6"/></svg></span>
            <span class="m-lab">Relations</span>
          </li>
        </ul>

        <!-- Section: Audio -->
        <div class="m-section">Audio</div>
        <ul>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2.5 8a5.5 5.5 0 0 1 11 0v4a1.5 1.5 0 0 1-1.5 1.5h-1V9h2.5"/><path d="M2.5 9H5v4.5H4A1.5 1.5 0 0 1 2.5 12V8"/></svg></span>
            <span class="m-lab">Studio</span>
            <span class="m-mono-tag">M4B</span>
          </li>
        </ul>

        <!-- Section: Project -->
        <div class="m-section">Project</div>
        <ul>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2.5 13.5h11M4 13.5V8M7 13.5V5M10 13.5V9.5M13 13.5V3.5"/></svg></span>
            <span class="m-lab">Analysis</span>
          </li>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2v8M5 7l3 3 3-3M3 13h10"/></svg></span>
            <span class="m-lab">Export</span>
            <span class="m-mono-tag">PDF</span>
          </li>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 4h10M5 4V2.5h6V4M4.5 4l.5 9.5h6L11.5 4M6.5 7v4M9.5 7v4"/></svg></span>
            <span class="m-lab">Trash</span>
          </li>
          <li>
            <span class="m-ico"><svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="2.2"/><path d="M8 1.5v2M8 12.5v2M1.5 8h2M12.5 8h2M3.4 3.4l1.4 1.4M11.2 11.2l1.4 1.4M3.4 12.6l1.4-1.4M11.2 4.8l1.4-1.4"/></svg></span>
            <span class="m-lab">Settings</span>
          </li>
        </ul>
      </aside>

      <!-- Main pane -->
      <article class="mockup-main">
        <!-- Pane header -->
        <header class="m-pane-head">
          <div class="m-pane-title">
            <div class="m-pane-eyebrow">Chapter 1 · Part One</div>
            <h2 class="m-pane-h1">The Quiet Hour</h2>
          </div>
          <div class="m-pane-actions">
            <span class="m-action-pill m-pill-gold">2,184 words</span>
            <span class="m-action-pill"><span class="m-pill-dot draft"></span> Draft</span>
            <span class="m-action-btn">⋯</span>
          </div>
        </header>

        <!-- Editor toolbar -->
        <div class="m-toolbar">
          <div class="m-tb-group">
            <span class="m-tb"><strong>B</strong></span>
            <span class="m-tb"><em>I</em></span>
            <span class="m-tb"><u>U</u></span>
          </div>
          <div class="m-tb-group">
            <span class="m-tb">H<sub>1</sub></span>
            <span class="m-tb">H<sub>2</sub></span>
            <span class="m-tb">¶</span>
          </div>
          <div class="m-tb-group">
            <span class="m-tb">“ ”</span>
            <span class="m-tb">* *</span>
            <span class="m-tb">⤶</span>
          </div>
          <div class="m-tb-group m-tb-right">
            <span class="m-tb m-tb-wide">Continuous</span>
            <span class="m-tb">⤺</span>
            <span class="m-tb">⤻</span>
          </div>
        </div>

        <!-- Manuscript page -->
        <div class="m-page">
          <div class="m-page-running">JUST · WRITE &nbsp; · &nbsp; CHAPTER 1 &nbsp; · &nbsp; PART ONE</div>
          <h3 class="m-page-h1">The Quiet Hour</h3>
          <div class="m-scene-break">* * *</div>
          <p>
            <span class="m-dropcap">T</span>he train pulled in just after the bells, and Iris stepped down onto a platform that smelled of rain and unsold flowers. She had imagined this town for so long that she could not, at first, believe it was real — that the hills were exactly the colour she had been writing them, and that the lamp by the station door was, indeed, the lamp.
          </p>
          <p>
            A man in a grey coat watched her without curiosity. He had been waiting for someone else.
          </p>
          <p>
            She turned up her collar. The river smelled of old paper.
          </p>
          <div class="m-page-folio"><em>1</em></div>
        </div>

        <!-- Status bar -->
        <footer class="m-statusbar">
          <span class="m-stat">
            <span class="m-stat-label">Session</span>
            <span class="m-stat-val"><strong>1,284</strong> w</span>
          </span>
          <span class="m-stat">
            <span class="m-stat-label">Streak</span>
            <span class="m-stat-val"><em>9 days</em></span>
          </span>
          <span class="m-stat m-stat-bar">
            <span class="m-stat-label">Daily</span>
            <span class="m-bar"><span style="width:64%"></span></span>
            <span class="m-stat-val">64%</span>
          </span>
          <span class="m-stat m-stat-end">
            <span class="m-stat-label">AI</span>
            <span class="m-stat-mono">ollama · llama3.1</span>
          </span>
        </footer>
      </article>
    </div>
  </div>
</div>

<style>
  .mockup {
    position: relative;
    width: 100%;
    isolation: isolate;
    transform: perspective(2400px) rotateX(2deg);
    transform-origin: 50% 100%;
  }
  .mockup-bg {
    position: absolute;
    inset: -8% -6% -10% -6%;
    border-radius: 32px;
    background:
      radial-gradient(60% 60% at 30% 20%, oklch(0.62 0.12 14 / 0.18), transparent 60%),
      radial-gradient(50% 50% at 80% 80%, oklch(0.62 0.10 320 / 0.18), transparent 60%);
    filter: blur(40px);
    z-index: -1;
  }

  .mockup-window {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: var(--shadow-deep);
    overflow: hidden;
    color: var(--ink);
  }

  /* ── Titlebar ─────────────────────────────────────────── */
  .mockup-titlebar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 14px;
    height: 38px;
    background: linear-gradient(180deg, var(--surface-2), var(--surface-3));
    border-bottom: 1px solid var(--border);
    font-family: var(--font-ui);
    font-size: 12px;
    color: var(--ink-2);
  }
  .dots { display: flex; gap: 7px; }
  .dots span {
    width: 11px; height: 11px; border-radius: 50%;
    background: var(--border-strong);
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.08);
  }
  .dots span:nth-child(1) { background: oklch(0.72 0.12 25); }
  .dots span:nth-child(2) { background: oklch(0.78 0.12 80); }
  .dots span:nth-child(3) { background: oklch(0.72 0.09 145); }
  .title {
    text-align: center;
    font-family: var(--font-serif);
    font-size: 12.5px;
    letter-spacing: -0.005em;
    color: var(--ink-2);
  }
  .title em { color: var(--accent); font-style: italic; }
  .title-right {
    display: flex; justify-content: flex-end; align-items: center; gap: 5px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--muted);
  }
  .title-right .kbd {
    display: inline-grid; place-items: center;
    min-width: 18px; height: 18px;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--surface);
    padding: 0 4px;
  }
  .title-right .theme-pill {
    width: 18px; height: 18px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: linear-gradient(135deg, var(--ink-2), var(--accent));
    margin-left: 6px;
  }

  /* ── Body grid ────────────────────────────────────────── */
  .mockup-body {
    display: grid;
    grid-template-columns: 230px 1fr;
    min-height: 540px;
  }

  /* ── Sidebar ─────────────────────────────────────────── */
  .mockup-side {
    background: var(--surface-2);
    border-right: 1px solid var(--border);
    padding: 10px 0 12px;
    font-size: 11.5px;
    color: var(--ink-2);
    overflow: hidden;
  }

  .m-brand {
    display: flex; align-items: center; gap: 9px;
    padding: 6px 12px 10px;
  }
  .m-mark {
    width: 22px; height: 22px; border-radius: 6px;
    background: linear-gradient(135deg, var(--accent), oklch(0.52 0.10 320));
    color: white; display: grid; place-items: center;
    font-family: var(--font-serif); font-style: italic;
    font-weight: 700; font-size: 14px;
    flex-shrink: 0;
  }
  .m-brand-text { display: flex; flex-direction: column; line-height: 1.15; min-width: 0; }
  .m-name { font-family: var(--font-serif); font-style: italic; font-weight: 600; color: var(--ink); font-size: 13px; }
  .m-sub { font-size: 9.5px; color: var(--muted); font-family: var(--font-mono); letter-spacing: 0.04em; }

  .m-proj {
    display: grid; grid-template-columns: 1fr auto;
    align-items: center; gap: 6px;
    margin: 0 10px 10px;
    padding: 7px 9px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .m-proj-main { min-width: 0; }
  .m-proj-title {
    font-size: 11.5px; font-weight: 600; color: var(--ink);
    letter-spacing: -0.005em; line-height: 1.2;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .m-proj-meta { font-size: 9.5px; color: var(--muted); margin-top: 1px; font-family: var(--font-mono); letter-spacing: 0.02em; }
  .m-proj-chev { color: var(--muted); font-size: 13px; line-height: 1; }

  .m-section {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 12px 16px 4px;
  }

  .mockup-side ul {
    list-style: none;
    margin: 0; padding: 0 6px;
    display: flex; flex-direction: column; gap: 0;
  }
  .mockup-side > ul > li {
    display: grid;
    grid-template-columns: 18px 1fr auto;
    align-items: center;
    gap: 9px;
    padding: 4px 8px 4px 6px;
    border-radius: 6px;
    color: var(--ink-2);
    font-size: 11.5px;
    line-height: 1.3;
  }
  .mockup-side > ul > li.active {
    background: var(--accent-soft);
    color: var(--accent-ink);
    font-weight: 500;
  }
  .mockup-side > ul > li.active .m-ico { color: var(--accent); }
  .m-ico {
    display: inline-flex; align-items: center; justify-content: flex-start;
    color: var(--muted);
  }
  .m-lab {
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .m-kbd, .m-count, .m-chev, .m-mono-tag {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }
  .m-count {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: 3px;
    padding: 0 5px;
    line-height: 14px;
    font-variant-numeric: tabular-nums;
  }
  .m-kbd {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: 3px;
    padding: 0 4px;
    line-height: 14px;
  }
  .m-chev {
    font-size: 11px;
    color: var(--muted);
    line-height: 1;
    transition: transform .14s ease;
  }
  .m-chev.open { transform: rotate(90deg); color: var(--accent); }
  .m-mono-tag {
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0 4px;
    border-radius: 3px;
    line-height: 14px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Expanded chapters block */
  .m-children {
    display: block !important;
    padding: 4px 0 4px 16px !important;
    margin-left: 9px;
    border-left: 1px solid var(--border);
  }
  .m-sub-head {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 10px;
    color: var(--subtle);
    padding: 6px 6px 4px 0;
    letter-spacing: 0.02em;
  }
  .m-chap-list {
    padding: 0 !important;
    margin: 0 0 4px !important;
    list-style: none;
  }
  .m-chap-list li {
    display: grid !important;
    grid-template-columns: 22px 1fr auto auto !important;
    gap: 7px !important;
    align-items: center;
    padding: 3px 6px 3px 0 !important;
    border-radius: 4px;
    font-size: 11px !important;
    line-height: 1.25;
    color: var(--ink-2);
  }
  .m-chap-list li.active {
    background: var(--accent-soft);
    color: var(--accent-ink) !important;
    font-weight: 500;
  }
  .m-num {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--muted);
    font-size: 11px;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .m-chap-list li.active .m-num { color: var(--accent); }
  .m-chap-label {
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .m-words {
    font-family: var(--font-mono);
    font-size: 9.5px;
    color: var(--subtle);
