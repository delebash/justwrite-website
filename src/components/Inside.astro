---
const { roman = "III" } = Astro.props;

const chapters = [
  {
    n: "I",
    label: "Manuscript",
    title: "The desk where you write.",
    body: "Rich text from a literary toolbar — bold, italic, headings, lists, links, tables, images. Scene boundaries with editable titles. Continuous mode that stitches scenes into one long page. Focus mode that hides everything else. Two page layouts: full-bleed or a traditional sheet with running head and folio. Markers dropped in the prose while drafting — fix-later, verify, weak passage, loose thread — collected on their own manuscript-wide page with one-click jumps back. Resume briefings and end-of-session recaps that summarise where you left off and what to pick up next. Find and replace. Smart quotes and em-dashes on the fly. Drag-to-reorder for scenes, chapters, parts.",
  },
  {
    n: "II",
    label: "Story world",
    title: "The world around the book.",
    body: "Characters with traits, motivations, and per-chapter arcs — and a consistency audit that flags contradictions between profile and prose. Locations, objects, groups. A relationship-arc tracker that maps how each bond evolves chapter by chapter. Three architecture documents — premise, fabula, setting — for the book's foundations. A free-form worldbuilding wiki with categories and tags. Notes. Per-entity event timelines that link back to scenes. A relations mind-map of who is in what with whom. A Find-new-entities sweep that surfaces characters and places the prose mentions but the Story Bible hasn't met yet.",
  },
  {
    n: "III",
    label: "Plot",
    title: "The bones of the story.",
    body: "Narrative strands tracked across multi-beat arcs. Built-in plot templates — Three-Act, Save the Cat, Hero's Journey, Story Circle — scaffolded with one click. A visual plot board where each strand reads across chapters. A beat-sheet overlay that maps your existing chapters onto a chosen structural framework. A plot-hole audit that walks the manuscript looking for setups without payoffs, character actions out of profile, and optional world-rule breaks. A dangling-thread tracker that lists foreshadowing the book never came back to. Scene-level linking to characters, places, objects, and strands. Per-scene status — To do · Draft · Revise · Done — surfaced everywhere as colour-coded donuts.",
  },
  {
    n: "IV",
    label: "AI",
    title: "Models, on your terms.",
    body: "Add any OpenAI-compatible endpoint — OpenAI, Ollama, LM Studio, llama.cpp, vLLM — like printers in a list. A per-feature model picker: one model for chat, another for critique, another for entity sweep. Ask-the-book chat with hybrid BM25 + vector retrieval and citations back to chapters. Talk to a character — converse with anyone in your cast, in their own voice. In-editor bubble actions: rewrite, expand, tighten, continue from cursor — or generate three alternatives side by side. Guided continue with a written brief. A voice canon (\"match my style\") fingerprint sampled from chapters you choose, injected into every generation. A stuck-on-this-chapter diagnostic that offers five distinct ways forward. A brainstorm pane for names, titles, plot twists, and next beats. A marketing pack — logline, blurbs, synopsis, pitch, and comp titles — when the book is ready to leave the desk. A multi-reader panel that critiques the chapter through several reader perspectives at once. A deterministic AI-tells scanner that flags stock verbs and clichés without spending a token. A Writer Lab that exposes every prompt and parsed result. A usage ledger that estimates the cost.",
  },
  {
    n: "V",
    label: "Audio Studio",
    title: "From cast list to finished file.",
    body: "A cast list mapping each character — and the narrator — to a voice from any TTS provider you've added. LLM-detected speakers per chapter, line by line, cached. A render queue across chapters. WAV concatenation with timed silences at speaker changes. Final mux to .m4b with ID3 chapter markers, cover art, and metadata. Plays in Audible, Apple Books, Plex — anything that reads M4B.",
  },
  {
    n: "VI",
    label: "Reflection",
    title: "Two views of the work.",
    body: "The Home dashboard: today's session, streak, fortnight, cadence — and a button that drops you back into the chapter you were last in. The Analysis surface: project KPIs, a thirty-day pace chart, a fifty-three-week writing-year heatmap, milestone tracking, status donuts, narrative-strand distribution, character-presence heatmap, dialogue versus narration versus interior monologue. A story-tension timeline that scores the rise and fall across chapters. A voice-drift report that flags chapters reading off-style, with per-chapter Explain. A reverse outline (StorySnap) that summarises what each chapter actually does versus what you remember it doing. A separate Reader-knowledge view that maps where the reader sits relative to the POV character — aligned, ahead, or behind — chapter by chapter, for mystery, thriller, and unreliable-narrator fiction.",
  },
  {
    n: "VII",
    label: "Import & Export",
    title: "What goes in, what comes out.",
    body: "Import DOCX, EPUB, ODT, Markdown, or plain text — with chapter auto-detection, image extraction, and smart-quote normalisation. Optional entity sweep on import to spot new characters and places. Export to PDF (TOC, part covers, cover image), DOCX (live auto-refreshing TOC), EPUB 3, or .m4b audiobook. Strip scene markers on export if you prefer.",
  },
  {
    n: "VIII",
    label: "Appearance",
    title: "The room, set up your way.",
    body: "Five built-in theme presets — Studio, Fine Press, Ivory Press, Calm Modern, Editorial. Light, dark, or follow the system. Four font pairings, with per-surface overrides. An accent-hue slider and a gold-hue slider. Surface and paper tints. Ink palettes. Button radius, density, and label-case. UI scale. Save your mix as a preset of your own.",
  },
];
---
<section id="inside" class="inside" data-folio>
  <div class="container">
    <header class="inside-head">
      <p class="eyebrow"><span class="roman">{roman}</span><span>A deeper look</span></p>
      <h2 class="section-title">Everything in <em>the rooms.</em></h2>
      <p class="section-lede">
        The six rooms above are how it's organised. Here is what is actually
        inside each of them — by category, in eight short chapters.
      </p>
    </header>

    <div class="inside-grid">
      {chapters.map((ch) => (
        <article class="chap">
          <div class="chap-head">
            <span class="chap-n">{ch.n}</span>
            <span class="chap-label">{ch.label}</span>
          </div>
          <h3 class="chap-title">{ch.title}</h3>
          <p class="chap-body">{ch.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .inside {
    background:
      radial-gradient(900px 600px at 50% 0%, oklch(0.62 0.10 14 / 0.05), transparent 60%),
      radial-gradient(800px 500px at 100% 100%, oklch(0.62 0.10 320 / 0.05), transparent 60%);
  }

  .inside-head { max-width: 56rem; margin-bottom: clamp(3rem, 6vw, 5rem); }

  .inside-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 4vw, 3.5rem) clamp(2rem, 4vw, 3.5rem);
  }
  @media (min-width: 880px) {
    .inside-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .chap {
    position: relative;
    padding-top: 2rem;
    border-top: 1px solid var(--border-strong);
  }

  .chap-head {
    display: flex; align-items: baseline; gap: 0.9rem;
    margin-bottom: 1.25rem;
  }
  .chap-n {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 2rem;
    line-height: 1;
    color: var(--accent);
    letter-spacing: 0;
    font-variation-settings: "SOFT" 70, "WONK" 1;
  }
  .chap-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .chap-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.45rem, 2.1vw, 1.75rem);
    line-height: 1.15;
    letter-spacing: -0.018em;
    color: var(--ink);
    margin: 0 0 1rem;
    max-width: 22ch;
  }

  .chap-body {
    font-family: var(--font-serif);
    font-size: clamp(0.98rem, 1.15vw, 1.05rem);
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0;
    max-width: 42ch;
  }
</style>
