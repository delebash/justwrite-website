---
<section id="inside" class="inside" data-folio>
  <div class="container">
    <header class="inside-head">
      <p class="eyebrow"><span class="roman">III</span><span>A deeper look</span></p>
      <h2 class="section-title">Everything in <em>the rooms.</em></h2>
      <p class="section-lede">
        The six rooms above are how it's organised. Here is what is actually
        inside each of them — by category, in eight short chapters.
      </p>
    </header>

    <div class="inside-grid">
      {chapters.map((ch) => (
        <article class="chap">
          <div class="chap-head">
            <span class="chap-n">{ch.n}</span>
            <span class="chap-label">{ch.label}</span>
          </div>
          <h3 class="chap-title">{ch.title}</h3>
          <p class="chap-body">{ch.body}</p>
          <ul class="chap-tags">
            {ch.tags.map((t) => <li>{t}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .inside {
    background:
      radial-gradient(900px 600px at 50% 0%, oklch(0.62 0.10 14 / 0.05), transparent 60%),
      radial-gradient(800px 500px at 100% 100%, oklch(0.62 0.10 320 / 0.05), transparent 60%);
  }

  .inside-head { max-width: 56rem; margin-bottom: clamp(3rem, 6vw, 5rem); }

  .inside-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 4vw, 3.5rem) clamp(2rem, 4vw, 3.5rem);
  }
  @media (min-width: 880px) {
    .inside-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .chap {
    position: relative;
    padding-top: 2rem;
    border-top: 1px solid var(--border-strong);
  }

  .chap-head {
    display: flex; align-items: baseline; gap: 0.9rem;
    margin-bottom: 1.25rem;
  }
  .chap-n {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 2rem;
    line-height: 1;
    color: var(--accent);
    letter-spacing: 0;
    font-variation-settings: "SOFT" 70, "WONK" 1;
  }
  .chap-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .chap-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.45rem, 2.1vw, 1.75rem);
    line-height: 1.15;
    letter-spacing: -0.018em;
    color: var(--ink);
    margin: 0 0 1rem;
    max-width: 22ch;
  }

  .chap-body {
    font-family: var(--font-serif);
    font-size: clamp(0.98rem, 1.15vw, 1.05rem);
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 1.5rem;
    max-width: 42ch;
  }

  .chap-tags {
    list-style: none;
    margin: 0; padding: 0;
    display: flex; flex-wrap: wrap;
    gap: 0.4rem 0.5rem;
  }
  .chap-tags li {
    display: inline-flex;
    padding: 0.25rem 0.55rem;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--ink-2);
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }
  .chap-tags li:hover {
    background: var(--accent-soft);
    color: var(--accent-ink);
    border-color: var(--accent-line);
  }
</style>
