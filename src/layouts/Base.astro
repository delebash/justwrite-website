---
import "../styles/global.css";
import PageFooter from "../components/PageFooter.astro";

const { title = "JustWrite — A writing instrument for the long form", description = "A desktop writing app for novelists. Manuscript editor, AI providers, audiobook export — built entirely by Claude Code." } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = Astro.url.pathname.replace(/\/$/, "");
const homePath = base || "/";

// Active-link detection. Docs has many sub-routes, so match by prefix.
const onOverview = path === base || path === "" || path === "/";
const onFeatures = path === `${base}/features`;
const onDocs = path.startsWith(`${base}/docs`);
---
<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,300..700,30..100,0..1;1,9..144,300..700,30..100,0..1&family=Spline+Sans:wght@300..700&family=Spline+Sans+Mono:wght@300..600&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      // Theme persistence — set BEFORE first paint to avoid flash.
      (function() {
        try {
          const saved = localStorage.getItem("jw-theme");
          if (saved === "light" || saved === "dark") {
            document.documentElement.setAttribute("data-theme", saved);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <!-- Persistent page chrome: brand left, nav center, folio right -->
    <div class="page-chrome">
      <a class="brand-lockup" href={homePath} aria-label="JustWrite home">
        <span class="mark">J</span>
        <span class="name">JustWrite</span>
      </a>

      <nav class="page-nav" aria-label="Primary">
        <a href={homePath} class:list={["nav-link", { active: onOverview }]}>Overview</a>
        <a href={`${base}/features`} class:list={["nav-link", { active: onFeatures }]}>Features</a>
        <a href={`${base}/docs/`} class:list={["nav-link", { active: onDocs }]}>Docs</a>
      </nav>

      <div class="folio">
        <span class="num" id="folio-num">i</span>
        <button class="toggle" id="theme-toggle" type="button" aria-label="Toggle theme" title="Toggle theme">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3a9 9 0 1 0 9 9 7 7 0 0 1-9-9z" />
          </svg>
        </button>
      </div>
    </div>

    <main id="top">
      <slot />
    </main>

    <PageFooter />

    <div id="lightbox" class="lightbox" hidden aria-hidden="true" role="dialog" aria-label="Image viewer">
      <button class="lightbox-close" type="button" aria-label="Close image viewer">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12" />
        </svg>
      </button>
      <button class="lightbox-nav lightbox-prev" type="button" aria-label="Previous image" hidden>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 18 9 12l6-6" />
        </svg>
      </button>
      <img id="lightbox-img" alt="" />
      <button class="lightbox-nav lightbox-next" type="button" aria-label="Next image" hidden>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m9 6 6 6-6 6" />
        </svg>
      </button>
      <div class="lightbox-counter" hidden aria-live="polite"></div>
    </div>

    <style>
      .page-nav {
        display: flex;
        gap: clamp(1rem, 3vw, 2rem);
        justify-content: center;
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
      }
      .nav-link {
        color: var(--muted);
        text-decoration: none;
        position: relative;
        padding: 4px 0;
        transition: color 150ms ease;
      }
      .nav-link:hover { color: var(--ink); }
      .nav-link.active {
        color: var(--accent);
      }
      .nav-link.active::after {
        content: "";
        position: absolute;
        left: 0; right: 0; bottom: -2px;
        height: 1px;
        background: var(--accent);
      }
      @media (max-width: 640px) {
        .page-nav { gap: 0.9rem; font-size: 10px; letter-spacing: 0.18em; }
      }

      /* ── Lightbox ────────────────────────────────────── */
      :global(img[data-zoomable]) { cursor: zoom-in; }
      .lightbox {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: clamp(1rem, 4vw, 3rem);
        background: rgba(0, 0, 0, 0.88);
        backdrop-filter: blur(4px);
        cursor: zoom-out;
        animation: lb-fade 140ms ease-out;
      }
      .lightbox[hidden],
      .lightbox-nav[hidden],
      .lightbox-counter[hidden] { display: none; }
      .lightbox img {
        max-width: min(100%, 1800px);
        max-height: 92vh;
        object-fit: contain;
        border-radius: 6px;
        box-shadow: 0 30px 90px rgba(0, 0, 0, 0.55);
        animation: lb-zoom 160ms ease-out;
      }
      .lightbox-close,
      .lightbox-nav {
        position: fixed;
        width: 44px; height: 44px;
        display: flex; align-items: center; justify-content: center;
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        cursor: pointer;
        transition: background 120ms ease, border-color 120ms ease, transform 120ms ease;
      }
      .lightbox-close {
        top: clamp(0.8rem, 2vw, 1.4rem);
        right: clamp(0.8rem, 2vw, 1.4rem);
        width: 40px; height: 40px;
      }
      .lightbox-nav {
        top: 50%;
        transform: translateY(-50%);
      }
      .lightbox-prev { left: clamp(0.8rem, 2vw, 1.6rem); }
      .lightbox-next { right: clamp(0.8rem, 2vw, 1.6rem); }
      .lightbox-close:hover,
      .lightbox-nav:hover {
        background: rgba(255, 255, 255, 0.18);
        border-color: rgba(255, 255, 255, 0.4);
      }
      .lightbox-nav:hover { transform: translateY(-50%) scale(1.05); }
      .lightbox-counter {
        position: fixed;
        bottom: clamp(1rem, 3vw, 2rem);
        left: 50%;
        transform: translateX(-50%);
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.7);
        background: rgba(0, 0, 0, 0.45);
        padding: 0.35rem 0.8rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
      }
      @media (max-width: 640px) {
        .lightbox-nav { width: 38px; height: 38px; }
      }
      @keyframes lb-fade { from { opacity: 0; } to { opacity: 1; } }
      @keyframes lb-zoom {
        from { opacity: 0; transform: scale(0.96); }
        to   { opacity: 1; transform: scale(1); }
      }
      @media (prefers-reduced-motion: reduce) {
        .lightbox, .lightbox img { animation: none; }
      }
    </style>

    <script is:inline>
      // Theme toggle
      const html = document.documentElement;
      const btn = document.getElementById("theme-toggle");
      btn?.addEventListener("click", () => {
        const next = html.getAttribute("data-theme") === "dark" ? "light" : "dark";
        html.setAttribute("data-theme", next);
        try { localStorage.setItem("jw-theme", next); } catch (e) {}
      });

      // Folio number cycles through roman numerals as you scroll past sections.
      // i → ii → iii → iv → v → vi → vii → viii
      const numerals = ["i", "ii", "iii", "iv", "v", "vi", "vii", "viii"];
      const sections = Array.from(document.querySelectorAll("section[data-folio]"));
      const folio = document.getElementById("folio-num");
      if (folio && sections.length && "IntersectionObserver" in window) {
        const io = new IntersectionObserver((entries) => {
          const visible = entries.filter(e => e.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio);
          if (visible.length) {
            const idx = sections.indexOf(visible[0].target);
            if (idx >= 0) folio.textContent = numerals[idx] || numerals[numerals.length - 1];
          }
        }, { rootMargin: "-40% 0px -40% 0px", threshold: [0, 0.25, 0.5, 0.75, 1] });
        sections.forEach(s => io.observe(s));
      }

      // Lightbox — click any img[data-zoomable] to enlarge; Esc / backdrop / X to close;
      // arrow keys or on-screen arrows step through every zoomable image on the page.
      (function () {
        const box = document.getElementById("lightbox");
        const bImg = document.getElementById("lightbox-img");
        if (!box || !bImg) return;
        const prevBtn = box.querySelector(".lightbox-prev");
        const nextBtn = box.querySelector(".lightbox-next");
        const counter = box.querySelector(".lightbox-counter");
        const closeBtn = box.querySelector(".lightbox-close");
        let images = [];
        let index = 0;
        let lastFocus = null;

        function show(i) {
          if (!images.length) return;
          index = (i + images.length) % images.length;
          const img = images[index];
          bImg.src = img.currentSrc || img.src;
          bImg.alt = img.alt || "";
          const multi = images.length > 1;
          prevBtn.hidden = !multi;
          nextBtn.hidden = !multi;
          counter.hidden = !multi;
          if (multi) counter.textContent = `${index + 1} / ${images.length}`;
        }
        function open(img) {
          lastFocus = document.activeElement;
          images = Array.from(document.querySelectorAll("img[data-zoomable]"));
          const i = images.indexOf(img);
          index = i >= 0 ? i : 0;
          box.hidden = false;
          box.setAttribute("aria-hidden", "false");
          document.body.style.overflow = "hidden";
          show(index);
          if (closeBtn) closeBtn.focus();
        }
        function close() {
          box.hidden = true;
          box.setAttribute("aria-hidden", "true");
          bImg.removeAttribute("src");
          document.body.style.overflow = "";
          if (lastFocus && lastFocus.focus) lastFocus.focus();
        }
        document.addEventListener("click", (e) => {
          const img = e.target.closest && e.target.closest("img[data-zoomable]");
          if (img) { e.preventDefault(); open(img); }
        });
        // Clicks inside the lightbox close it — except on the prev/next/close controls.
        box.addEventListener("click", (e) => {
          if (e.target.closest(".lightbox-nav") || e.target.closest(".lightbox-close")) return;
          close();
        });
        prevBtn.addEventListener("click", (e) => { e.stopPropagation(); show(index - 1); });
        nextBtn.addEventListener("click", (e) => { e.stopPropagation(); show(index + 1); });
        if (closeBtn) closeBtn.addEventListener("click", (e) => { e.stopPropagation(); close(); });
        document.addEventListener("keydown", (e) => {
          if (box.hidden) return;
          if (e.key === "Escape") close();
          else if (e.key === "ArrowLeft") show(index - 1);
          else if (e.key === "ArrowRight") show(index + 1);
        });
      })();
    </script>
  </body>
</html>
