---
import Base from "./Base.astro";
// TOC is sourced from justwrite-app/docs/toc.json — shipped in
// docs.tar.gz on each release, written here by scripts/sync-docs.mjs.
// Single source of truth shared with the in-app Help viewer.
import TOC from "../data/docs-toc.json";

const { frontmatter } = Astro.props;
const title = frontmatter?.title || "Docs";
const slug = frontmatter?.slug || "index";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const docHref = (s) => s === "index" || !s ? `${base}/docs/` : `${base}/docs/${s}/`;
const isActive = (s) => slug === (s || "index");
---
<Base title={`${title} — JustWrite Docs`} description={`JustWrite user documentation: ${title}.`}>
  <section class="docs-page">
    <div class="docs-shell">
      <aside class="docs-toc" aria-label="Documentation table of contents">
        <div class="docs-search" role="search">
          <input
            type="search"
            id="docs-search-input"
            class="docs-search-input"
            placeholder="Search docs…"
            autocomplete="off"
            spellcheck="false"
            aria-label="Search documentation"
          />
          <div id="docs-search-results" class="docs-search-results" hidden></div>
        </div>

        <a class={`toc-item toc-index${isActive("index") ? " active" : ""}`} href={docHref("")}>
          <span class="toc-title">Overview</span>
          <span class="toc-hint">What JustWrite is, where to start</span>
        </a>

        {TOC.map((group) => (
          <div class="toc-group">
            <div class="toc-section">{group.section}</div>
            {group.items.map((item) => (
              <a class={`toc-item${isActive(item.slug) ? " active" : ""}`} href={docHref(item.slug)}>
                <span class="toc-title">{item.title}</span>
                <span class="toc-hint">{item.hint}</span>
              </a>
            ))}
          </div>
        ))}
      </aside>

      <main class="docs-content">
        <header class="docs-header">
          <p class="eyebrow"><span>JustWrite Docs</span></p>
          <h1 class="docs-title">{title}</h1>
        </header>
        <article class="docs-prose" data-pagefind-body>
          <slot />
        </article>
      </main>
    </div>
  </section>

  <script define:vars={{ pagefindUrl: `${base}/pagefind/pagefind.js` }}>
    const input = document.getElementById("docs-search-input");
    const out = document.getElementById("docs-search-results");
    if (input && out) {
      let pagefind = null;
      let loadFailed = false;
      async function getPagefind() {
        if (pagefind || loadFailed) return pagefind;
        try {
          pagefind = await import(/* @vite-ignore */ pagefindUrl);
          if (pagefind.options) await pagefind.options({ excerptLength: 28 });
        } catch (e) {
          loadFailed = true;
        }
        return pagefind;
      }
      const escape = (s) => String(s).replace(/[&<>"']/g, (c) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;"
      }[c]));
      let t;
      input.addEventListener("input", () => {
        clearTimeout(t);
        const q = input.value.trim();
        if (!q) { out.hidden = true; out.innerHTML = ""; return; }
        t = setTimeout(async () => {
          const pf = await getPagefind();
          if (!pf) {
            out.hidden = false;
            out.innerHTML = '<div class="docs-search-note">Search index is built on <code>npm run build</code>; not available in <code>dev</code>.</div>';
            return;
          }
          const r = await pf.search(q);
          if (!r.results.length) {
            out.hidden = false;
            out.innerHTML = '<div class="docs-search-note">No matches.</div>';
            return;
          }
          const top = r.results.slice(0, 8);
          const data = await Promise.all(top.map(x => x.data()));
          out.hidden = false;
          out.innerHTML = data.map(d => {
            const title = escape(d.meta?.title || d.url);
            const excerpt = d.excerpt || "";
            return `<a class="docs-search-result" href="${escape(d.url)}"><span class="r-title">${title}</span><span class="r-excerpt">${excerpt}</span></a>`;
          }).join("");
        }, 150);
      });
      input.addEventListener("keydown", (e) => {
        if (e.key === "Escape") { input.value = ""; out.hidden = true; out.innerHTML = ""; input.blur(); }
      });
    }
  </script>
</Base>

<style>
  .docs-page {
    padding: clamp(2rem, 4vw, 4rem) var(--gutter) clamp(4rem, 8vw, 6rem);
    max-width: var(--measure-wide);
    margin: 0 auto;
  }
  .docs-shell {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3rem);
  }
  @media (min-width: 880px) {
    .docs-shell { grid-template-columns: 260px minmax(0, 1fr); }
  }

  .docs-toc {
    position: sticky;
    top: 80px;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    padding-right: 0.5rem;
  }
  .docs-search { margin-bottom: 1rem; position: relative; }
  .docs-search-input {
    width: 100%;
    box-sizing: border-box;
    padding: 0.55rem 0.7rem;
    font-family: var(--font-sans, system-ui);
    font-size: 0.9rem;
    color: var(--ink);
    background: var(--paper, transparent);
    border: 1px solid var(--border);
    border-radius: 8px;
    outline: none;
    transition: border-color 120ms ease, background 120ms ease;
  }
  .docs-search-input::placeholder { color: var(--muted); }
  .docs-search-input:focus {
    border-color: color-mix(in oklab, var(--accent) 60%, transparent);
    background: color-mix(in oklab, var(--accent) 4%, transparent);
  }
  .docs-search-results {
    margin-top: 0.5rem;
    padding: 0.3rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: color-mix(in oklab, var(--ink) 3%, transparent);
    max-height: 60vh;
    overflow-y: auto;
  }
  .docs-search-result {
    display: flex;
    flex-direction: column;
    padding: 0.5rem 0.55rem;
    border-radius: 6px;
    color: var(--ink-2);
    text-decoration: none;
    transition: background 120ms ease, color 120ms ease;
  }
  .docs-search-result:hover {
    background: color-mix(in oklab, var(--accent) 10%, transparent);
    color: var(--ink);
  }
  .docs-search-result .r-title { font-size: 0.9rem; font-weight: 500; }
  .docs-search-result .r-excerpt {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.45;
    margin-top: 0.15rem;
  }
  .docs-search-result :global(mark) {
    background: color-mix(in oklab, var(--accent) 25%, transparent);
    color: var(--ink);
    padding: 0 2px;
    border-radius: 2px;
  }
  .docs-search-note {
    padding: 0.55rem 0.6rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .docs-search-note :global(code) {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 0.82em;
  }

  .toc-group { margin-top: 1.4rem; }
  .toc-section {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 0 0.6rem 0.5rem;
  }
  .toc-item {
    display: flex;
    flex-direction: column;
    padding: 0.55rem 0.6rem;
    margin-bottom: 0.15rem;
    border-radius: 8px;
    border: 1px solid transparent;
    color: var(--ink-2);
    transition: background 120ms ease, border-color 120ms ease, color 120ms ease;
  }
  .toc-item:hover {
    background: color-mix(in oklab, var(--accent) 8%, transparent);
    color: var(--ink);
  }
  .toc-item.active {
    background: color-mix(in oklab, var(--accent) 14%, transparent);
    border-color: color-mix(in oklab, var(--accent) 45%, transparent);
    color: var(--ink);
  }
  .toc-index { margin-bottom: 0.4rem; }
  .toc-title { font-size: 0.95rem; font-weight: 500; }
  .toc-hint {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--muted);
    margin-top: 0.1rem;
    line-height: 1.4;
  }

  .docs-header { margin-bottom: 2.5rem; }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.8rem;
  }
  .docs-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0;
    color: var(--ink);
  }

  .docs-prose {
    max-width: 720px;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--ink);
  }
  .docs-prose :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    margin: 2.5em 0 0.7em;
    padding-bottom: 0.3em;
    border-bottom: 1px solid var(--border);
    color: var(--ink);
  }
  .docs-prose :global(h3) {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    margin: 2em 0 0.6em;
    color: var(--ink);
  }
  .docs-prose :global(p) { margin: 0 0 1em; }
  .docs-prose :global(ul),
  .docs-prose :global(ol) { margin: 0 0 1em 1.5em; padding: 0; }
  .docs-prose :global(li) { margin-bottom: 0.35em; }
  .docs-prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--accent-line);
    text-underline-offset: 3px;
  }
  .docs-prose :global(a:hover) { text-decoration-color: var(--accent); }
  .docs-prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: color-mix(in oklab, var(--ink) 8%, transparent);
    padding: 1px 5px;
    border-radius: 4px;
  }
  .docs-prose :global(pre) {
    background: color-mix(in oklab, var(--ink) 6%, transparent);
    padding: 1rem 1.2rem;
    border-radius: 8px;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0 0 1.2em;
  }
  .docs-prose :global(pre code) { background: transparent; padding: 0; }
  .docs-prose :global(blockquote) {
    margin: 0 0 1em;
    padding: 0.5em 1em;
    border-left: 3px solid var(--accent);
    color: var(--muted);
    font-style: italic;
  }
  .docs-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 1.4em;
    font-size: 0.95rem;
    font-family: var(--font-sans, system-ui);
  }
  .docs-prose :global(th),
  .docs-prose :global(td) {
    border: 1px solid var(--border);
    padding: 0.5em 0.7em;
    text-align: left;
    vertical-align: top;
  }
  .docs-prose :global(th) {
    background: color-mix(in oklab, var(--ink) 5%, transparent);
    font-weight: 600;
  }
  .docs-prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 2.5em 0;
  }
  .docs-prose :global(strong) { font-weight: 600; color: var(--ink); }
  .docs-prose :global(em) { font-style: italic; }
</style>
